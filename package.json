{
  "name": "calyroc",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv src/cloudflare-env.d.ts",
    "postinstall": "wrangler types --env-interface CloudflareEnv src/cloudflare-env.d.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/bun": "latest",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@unocss/postcss": "^66.7.5",
    "postcss": "^8.5.16",
    "typescript": "^6",
    "unocss": "^66.7.5",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.17.2",
    "stripe": "^22.3.1",
    "zod": "^4.4.3"
  }
}
