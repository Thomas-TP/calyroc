# Resend -- contact form emails (src/app/actions.ts)
RESEND_API_KEY=
CALYROC_CONTACT_TO=hello@calyroc.com
RESEND_FROM_EMAIL=Calyroc <hello@calyroc.com>

# Admin space (/admin) -- src/lib/adminAuth.ts
# ADMIN_PASSWORD: the login password, pick something strong.
# ADMIN_SESSION_SECRET: random string used to sign the session cookie, e.g. `openssl rand -hex 32`.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Stripe -- admin-generated deposit payment links (src/lib/stripe.ts,
# src/app/admin/actions.ts). Use a restricted/secret key with Checkout Session
# write access.
STRIPE_SECRET_KEY=

# Stripe webhook signature verification (src/app/api/stripe/webhook/route.ts).
# Copy from the webhook endpoint's "Signing secret" in the Stripe Dashboard
# after registering https://calyroc.com/api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=
